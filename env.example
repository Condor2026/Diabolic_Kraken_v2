# ============================================
# KELTIC KRAKEN v3.0 - Variables de Entorno
# Copia este archivo a .env y modifica
# ============================================

# Web Server
PORT=5014
HOST=127.0.0.1

# Scraping
PAGINAS_BUSQUEDA=5
TIMEOUT=25
MAX_INTENTOS=3
DELAY_MIN=0.8
DELAY_MAX=2.0

# Auto-discovery
AUTO_DISCOVERY=true
URL_CACHE_ENABLED=true

# Archivos
DATA_FILE=keltic-kraken_ireland.json
BACKUP_FILE=keltic-kraken_backup.json
URL_CACHE_FILE=url_cache_ireland.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=keltic-kraken.log
